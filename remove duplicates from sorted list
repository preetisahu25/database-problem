class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        if (!head) return nullptr;

        ListNode* dummy = new ListNode(head->val);
        ListNode* tail = dummy;

        int lastVal = head->val;
        head = head->next;

        while (head) {
            if (head->val != lastVal) {
                tail->next = new ListNode(head->val);
                tail = tail->next;
                lastVal = head->val;
            }
            head = head->next;
        }

        return dummy;
    }
};
